# ============================================================
# Application
# ============================================================
ENV=dev
LOG_LEVEL=INFO
LOG_JSON=false

# ============================================================
# LLM Provider Configuration
# Switch between providers by changing LLM_PROVIDER.
# Ollama (local, free) vs OpenAI (cloud, paid).
# ============================================================

# --- Default: Local Ollama ---
LLM_PROVIDER=ollama
LLM_MODEL=llama3.2:latest
LLM_BASE_URL=http://localhost:11434/v1
LLM_API_KEY=ollama-no-key-needed
LLM_TIMEOUT_SECONDS=60
LLM_TEMPERATURE=0.1

# --- To switch to OpenAI, comment the above and uncomment below ---
# LLM_PROVIDER=openai
# LLM_MODEL=gpt-4o-mini
# LLM_BASE_URL=https://api.openai.com/v1
# LLM_API_KEY=sk-YOUR-KEY-HERE
# LLM_TIMEOUT_SECONDS=30
# LLM_TEMPERATURE=0.1

# ============================================================
# Agent Guardrails
# ============================================================
AGENT_MAX_ITERATIONS=5
AGENT_MAX_TOKENS_PER_CALL=1024
AGENT_DAILY_BUDGET_USD=0.50